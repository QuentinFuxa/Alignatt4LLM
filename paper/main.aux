\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Clean EN$\to $DE rerun at $\Delta _{\mathrm  {chunk}}=1100$ ms.} This maintained rerun keeps the deployed Qwen3-ASR forced backend, the Gemma AlignAtt MT backend, the retained top-8 MT head set, border margin 1, and min-start 2.0 s, but removes the historical MT rewind policy used in the frozen submitted low-regime bundles. We report it separately from Table\nobreakspace  {}\ref  {tab:e2e} because it is a cleaner maintenance rerun rather than a submitted operating point.\relax }}{7}{table.caption.11}\protected@file@percent }
\newlabel{tab:low-config-snapshot}{{2}{7}{\textbf {Clean EN$\to $DE rerun at $\Delta _{\mathrm {chunk}}=1100$ ms.} This maintained rerun keeps the deployed Qwen3-ASR forced backend, the Gemma AlignAtt MT backend, the retained top-8 MT head set, border margin 1, and min-start 2.0 s, but removes the historical MT rewind policy used in the frozen submitted low-regime bundles. We report it separately from Table~\ref {tab:e2e} because it is a cleaner maintenance rerun rather than a submitted operating point.\relax }{table.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {EN$\to $DE full-MCIF MT head-set comparison at $\Delta _{\mathrm  {chunk}}=1100$ ms.} Both rows use the same maintained runtime and no MT rewind policy; only the MT head set changes. All-head replay is slightly better on XCOMET-XL, but increases CU and especially CA because the runtime must reconstruct more attention at each MT step.\relax }}{7}{table.caption.12}\protected@file@percent }
\newlabel{tab:mt-e2e-head-filtering}{{3}{7}{\textbf {EN$\to $DE full-MCIF MT head-set comparison at $\Delta _{\mathrm {chunk}}=1100$ ms.} Both rows use the same maintained runtime and no MT rewind policy; only the MT head set changes. All-head replay is slightly better on XCOMET-XL, but increases CU and especially CA because the runtime must reconstruct more attention at each MT step.\relax }{table.caption.12}{}}
