\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Compile-safe observer lifecycle on the deployed vLLM path.} \emph  {Left (A), once, before graph capture:} the forward of \texttt  {GemmaAttention} is patched so that for each selected head $(\ell ,h)\in \mathcal  {H}$ the query and key tensors also pass through an observer custom op $\phi _{\mathrm  {cap}}$ (dashed orange side path). The op writes the selected slices into fixed-shape, pre-allocated slots and returns a zero tensor that is added back into the attention output; this keeps the op in the live fan-in of the graph so the compiler cannot dead-code-eliminate it, while the numerical output of the layer is unchanged. \emph  {Right (B), every forward:} after the compiled forward finishes, the observer slots hold $\mathbf  {K}^{(\ell ,h)}_{\mathcal  {P}}$ for the full prompt and $\mathbf  {Q}^{(\ell ,h)}_{\mathcal  {D}}$ for the draft rows; a short Python-side replay reapplies the module scaling and the same prompt/suffix masks used by the deployed attention kernel, then keeps the source columns to yield the selective block $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle \mathbf  {A}$}\mathaccent "0362{\mathbf  {A}}^{(\ell ,h)}_{\mathcal  {D},\mathcal  {S}^{(k)}}$ that feeds the policy, the parity check against an uncompiled Transformers reference, and the qualitative probe.\relax }}{6}{figure.caption.9}\protected@file@percent }
\newlabel{fig:observer-lifecycle}{{5}{6}{\textbf {Compile-safe observer lifecycle on the deployed vLLM path.} \emph {Left (A), once, before graph capture:} the forward of \texttt {GemmaAttention} is patched so that for each selected head $(\ell ,h)\in \mathcal {H}$ the query and key tensors also pass through an observer custom op $\phi _{\mathrm {cap}}$ (dashed orange side path). The op writes the selected slices into fixed-shape, pre-allocated slots and returns a zero tensor that is added back into the attention output; this keeps the op in the live fan-in of the graph so the compiler cannot dead-code-eliminate it, while the numerical output of the layer is unchanged. \emph {Right (B), every forward:} after the compiled forward finishes, the observer slots hold $\mathbf {K}^{(\ell ,h)}_{\mathcal {P}}$ for the full prompt and $\mathbf {Q}^{(\ell ,h)}_{\mathcal {D}}$ for the draft rows; a short Python-side replay reapplies the module scaling and the same prompt/suffix masks used by the deployed attention kernel, then keeps the source columns to yield the selective block $\widehat {\mathbf {A}}^{(\ell ,h)}_{\mathcal {D},\mathcal {S}^{(k)}}$ that feeds the policy, the parity check against an uncompiled Transformers reference, and the qualitative probe.\relax }{figure.caption.9}{}}
