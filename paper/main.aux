\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Selective reconstruction with engine-native capture.} The $n{\times }n$ attention matrix $\mathbf  {A}^{(\ell ,h)}$ is executed entirely inside the fused attention kernel, so the full $n{\times }n$ matrix is never materialized. For each AlignAtt head $(\ell ,h)\in \mathcal  {H}$, the observer copies $\mathbf  {K}^{(\ell ,h)}$ for all positions and $\mathbf  {Q}^{(\ell ,h)}$ only for the draft rows $\mathcal  {D}$ into fixed-shape buffers. The green band $\mathbf  {y}_{1:m_k}$ inside $\mathcal  {P}_2$ marks the committed target prefix that grows across chunks; hatched cells are never reconstructed. After the forward, Eq.\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:mt-qk-fast}\unskip \@@italiccorr )}} recomputes exactly only the draft-to-source block $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle \mathbf  {A}$}\mathaccent "0362{\mathbf  {A}}_{\mathcal  {D},\mathcal  {S}^{(k)}}$, which is the sole object consumed by the source-side provenance scores of Eqs.\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:mt-prov-acc}\unskip \@@italiccorr )}}--\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:mt-provenance}\unskip \@@italiccorr )}} and by the acceptance policy of this section.\relax }}{4}{figure.caption.7}\protected@file@percent }
\newlabel{fig:qk-fast}{{3}{4}{\textbf {Selective reconstruction with engine-native capture.} The $n{\times }n$ attention matrix $\mathbf {A}^{(\ell ,h)}$ is executed entirely inside the fused attention kernel, so the full $n{\times }n$ matrix is never materialized. For each AlignAtt head $(\ell ,h)\in \mathcal {H}$, the observer copies $\mathbf {K}^{(\ell ,h)}$ for all positions and $\mathbf {Q}^{(\ell ,h)}$ only for the draft rows $\mathcal {D}$ into fixed-shape buffers. The green band $\mathbf {y}_{1:m_k}$ inside $\mathcal {P}_2$ marks the committed target prefix that grows across chunks; hatched cells are never reconstructed. After the forward, Eq.~\eqref {eq:mt-qk-fast} recomputes exactly only the draft-to-source block $\widehat {\mathbf {A}}_{\mathcal {D},\mathcal {S}^{(k)}}$, which is the sole object consumed by the source-side provenance scores of Eqs.~\eqref {eq:mt-prov-acc}--\eqref {eq:mt-provenance} and by the acceptance policy of this section.\relax }{figure.caption.7}{}}
