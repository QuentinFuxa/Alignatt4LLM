\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Architecture-aware view of retained MT alignment heads.} The useful MT heads are sparse, late, and only partly overlap with the ASR set, which highlights role-specific specialization. Their clustering inside the late shared-KV block is favorable because observer cost follows KV-group ownership rather than raw query-head count.\relax }}{10}{figure.caption.14}\protected@file@percent }
\newlabel{fig:mt-alignatt-heads}{{8}{10}{\textbf {Architecture-aware view of retained MT alignment heads.} The useful MT heads are sparse, late, and only partly overlap with the ASR set, which highlights role-specific specialization. Their clustering inside the late shared-KV block is favorable because observer cost follows KV-group ownership rather than raw query-head count.\relax }{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Word-level selective reconstruction on a live MT draft.} \emph  {Top ribbon:} prompt partition into system instruction, live source, accepted target prefix, and current draft. \emph  {Left panel:} reconstructed draft-to-source attention from the selected AlignAtt heads, aggregated to words and split by the dashed accessibility frontier; black stars stay on the accessible side, while the first red star marks the \textsc  {source-frontier} failure. \emph  {Right panel:} each drafted word is decomposed into accessible-source, inaccessible-source, prompt, and suffix mass, with the numeric label giving the total source share.\relax }}{10}{figure.caption.18}\protected@file@percent }
