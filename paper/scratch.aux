\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Selective reconstruction with engine-native capture.} The $n{\times }n$ attention matrix $\mathbf  {A}^{(\ell ,h)}$ is executed entirely inside the fused attention kernel, so the full $n{\times }n$ matrix is never materialized. For each AlignAtt head $(\ell ,h)\in \mathcal  {H}$, the observer copies $\mathbf  {K}^{(\ell ,h)}$ for all positions and $\mathbf  {Q}^{(\ell ,h)}$ only for the draft rows $\mathcal  {D}$ into fixed-shape buffers. After the forward, Eq.\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:qk-fast}\unskip \@@italiccorr )}} recomputes exactly only the draft-to-source block $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle \mathbf  {A}$}\mathaccent "0362{\mathbf  {A}}_{\mathcal  {D},\mathcal  {S}^{(k)}}$, which is the sole object consumed by the source-side provenance scores of Eqs.\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:prov-acc}\unskip \@@italiccorr )}}--\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:provenance}\unskip \@@italiccorr )}} and by the acceptance policy of this section.}}{6}{figure.3}\protected@file@percent }
\newlabel{fig:qk-fast}{{3}{6}{\textbf {Selective reconstruction with engine-native capture.} The $n{\times }n$ attention matrix $\mathbf {A}^{(\ell ,h)}$ is executed entirely inside the fused attention kernel, so the full $n{\times }n$ matrix is never materialized. For each AlignAtt head $(\ell ,h)\in \mathcal {H}$, the observer copies $\mathbf {K}^{(\ell ,h)}$ for all positions and $\mathbf {Q}^{(\ell ,h)}$ only for the draft rows $\mathcal {D}$ into fixed-shape buffers. After the forward, Eq.~\eqref {eq:qk-fast} recomputes exactly only the draft-to-source block $\widehat {\mathbf {A}}_{\mathcal {D},\mathcal {S}^{(k)}}$, which is the sole object consumed by the source-side provenance scores of Eqs.~\eqref {eq:prov-acc}--\eqref {eq:provenance} and by the acceptance policy of this section}{figure.3}{}}
