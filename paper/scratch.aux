\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Operational view of the decoder-only cascade.} A single decoder-only Gemma checkpoint is queried twice per input chunk: first in the ASR role (audio$\to $text) to confirm a transcript prefix, then in the MT role (text$\to $text) to extend the translation from the visible source span. In the runtime this appears as two sequential vLLM requests with role-specific AlignAtt observers ($\mathcal  {H}_{\mathrm  {ASR}}$ and $\mathcal  {H}_{\mathrm  {MT}}$), each reconstructing only the draft-to-source block consumed by its gate. The confirmed ASR transcript prefix feeds the MT source span, and the accepted target prefix is reused as causal target prefill for the next MT step.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:dual-alignatt-cascade}{{1}{3}{\textbf {Operational view of the decoder-only cascade.} A single decoder-only Gemma checkpoint is queried twice per input chunk: first in the ASR role (audio$\to $text) to confirm a transcript prefix, then in the MT role (text$\to $text) to extend the translation from the visible source span. In the runtime this appears as two sequential vLLM requests with role-specific AlignAtt observers ($\mathcal {H}_{\mathrm {ASR}}$ and $\mathcal {H}_{\mathrm {MT}}$), each reconstructing only the draft-to-source block consumed by its gate. The confirmed ASR transcript prefix feeds the MT source span, and the accepted target prefix is reused as causal target prefill for the next MT step}{figure.1}{}}
